<!DOCTYPE html>
<html lang="pt-br">
<head>
<meta charset="UTF-8">
<title>Sistema ESF</title>

<style>

body{
    margin: 0;
    background: linear-gradient(135deg, #1e3c72, #2a5298);
    font-family: Arial, sans-serif;
}

/* Título no topo */
.topo{
    width: 100%;
    background-color: #16315f;
    color: white;
    text-align: center;
    padding: 20px 0;
    font-size: 35px;
    font-weight: bold;
    box-shadow: 0px 2px 10px rgba(0,0,0,0.3);
}

/* Centraliza apenas o formulário */
.container{
    display: flex;
    justify-content: center;
    align-items: center;
    height: calc(100vh - 90px);
}

form{
    background-color: white;
    padding: 30px;
    border-radius: 15px;
    width: 300px;
    box-shadow: 0px 0px 15px rgba(0,0,0,0.3);
}

h1{
    text-align: center;
    color: #1e3c72;
}

label{
    font-weight: bold;
    color: #333;
}

input{
    width: 100%;
    padding: 10px;
    margin-top: 5px;
    margin-bottom: 15px;
    border: 2px solid #ccc;
    border-radius: 8px;
    outline: none;
}

input:focus{
    border-color: #2a5298;
}

button{
    width: 100%;
    padding: 12px;
    background-color: #2a5298;
    color: white;
    border: none;
    border-radius: 8px;
    font-size: 16px;
    cursor: pointer;
}

button:hover{
    background-color: #1e3c72;
}

</style>
</head>

<body>

    <!-- Título -->
    <div class="topo">
        Sistema ESF
    </div>

    <!-- Formulário -->
    <div class="container">

    </div>

</body>
</html>